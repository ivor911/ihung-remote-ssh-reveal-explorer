{
  "name": "ihung-remote-ssh-reveal-explorer",
  "displayName": "Remote-SSH Reveal in File Explorer (ihung)",
  "description": "Open Windows File Explorer from Remote-SSH. Directories open inside the folder; files are selected with explorer /select.",
  "version": "1.2.5",
  "icon": "assets/imgs/logo.png",
  "author": {
    "name": "ihung (ivor911)"
  },
  "publisher": "ivor911",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivor911/ihung-remote-ssh-reveal-explorer"
  },
  "bugs": {
    "url": "https://github.com/ivor911/ihung-remote-ssh-reveal-explorer/issues"
  },
  "homepage": "https://github.com/ivor911/ihung-remote-ssh-reveal-explorer#readme",
  "keywords": [
    "remote-ssh",
    "windows",
    "explorer",
    "file manager",
    "reveal",
    "context menu",
    "cursor"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "type": "module",
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onCommand:remote-ssh-reveal-explorer.revealInExplorer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "remote-ssh-reveal-explorer.revealInExplorer",
        "title": "Remote-SSH Reveal in File Explorer"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "remote-ssh-reveal-explorer.revealInExplorer",
          "when": "remoteName == ssh-remote && isWindows",
          "group": "6_copypath@1000"
        }
      ],
      "editor/title/context": [
        {
          "command": "remote-ssh-reveal-explorer.revealInExplorer",
          "when": "remoteName == ssh-remote && isWindows",
          "group": "2_files"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Remote-SSH Reveal",
      "properties": {
        "remote-ssh-reveal-explorer.networkPath": {
          "type": "string",
          "default": "",
          "description": "Path to the network folder of the Remote-SSH machine (UNC or mapped drive, e.g. \\\\host\\share or K:).",
          "scope": "window"
        },
        "remote-ssh-reveal-explorer.pathPrefixToStrip": {
          "type": "string",
          "default": "",
          "description": "Prefix to strip from the remote path (e.g. /home/username).",
          "scope": "window"
        },
        "remote-ssh-reveal-explorer.showSuccessNotification": {
          "type": "boolean",
          "default": false,
          "description": "Show an information message after successfully revealing a path in File Explorer.",
          "scope": "window"
        }
      }
    },
    "keybindings": [
      {
        "key": "shift+alt+r",
        "command": "remote-ssh-reveal-explorer.revealInExplorer",
        "when": "editorTextFocus && remoteName == 'ssh-remote' && isWindows"
      },
      {
        "key": "shift+alt+r",
        "command": "remote-ssh-reveal-explorer.revealInExplorer",
        "when": "filesExplorerFocus && !editorTextFocus && remoteName == 'ssh-remote' && isWindows",
        "args": "${resource}"
      }
    ]
  },
  "scripts": {
    "test": "npm run compile && node --test test/pathUtils.test.mjs",
    "compile": "tsc -p ./",
    "build": "vsce build",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}
